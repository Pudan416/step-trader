    "Heart" : {
      "comment" : "CategoryDetail – energy category name\nEnergy category\nRadialMenu – energy category label"
    },
    "Heart tracks joys and things that make you feel alive. Pick up to 4 cards for %lld colors (%lld colors today)." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
