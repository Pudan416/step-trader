// Release secrets layer (§6.1)
//
// Inherits the shared production client keys from Secrets.xcconfig. Keep this
// pointed at the production Supabase project. The runtime host assertion in
// SupabaseConfig (NetworkClient.swift) rejects any non-`*.supabase.co` HTTPS
// URL in Release builds, so a mis-wired endpoint fails fast instead of
// silently shipping. No secret values live here — see Secrets.xcconfig.

#include "Secrets.xcconfig"

// Release-only overrides go below (normally none).
