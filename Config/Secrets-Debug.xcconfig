// Debug secrets layer (§6.1)
//
// Inherits the shared public client keys from Secrets.xcconfig, then lets
// Debug builds override individual values — e.g. point SUPABASE_URL at a
// staging project — without touching Release. No secret values live here:
// the actual keys stay in the gitignored Secrets.xcconfig (created locally
// from Secrets.xcconfig.template, or by ci_scripts/ci_post_clone.sh on CI).

#include "Secrets.xcconfig"

// Debug-only overrides go below. Example — point Debug at a staging Supabase:
// SUPABASE_URL = https:/$()/your-staging-ref.supabase.co
