// Debug secrets layer (§6.1)
//
// Inherits the shared public client keys from Secrets.xcconfig, then optionally
// overrides them for Debug from Secrets-Dev.xcconfig so local/dev builds hit the
// dev Supabase project (doom-ctrl-dev) instead of production. No secret values
// live here: prod keys stay in the gitignored Secrets.xcconfig; dev keys stay in
// the gitignored Secrets-Dev.xcconfig (both created from their *.template files).
//
// The dev include is OPTIONAL (`#include?`): if Secrets-Dev.xcconfig is absent —
// e.g. on CI, or on a fresh clone before it's created — Debug simply falls back
// to the prod values from Secrets.xcconfig and still builds. Later includes win,
// so when present, Secrets-Dev.xcconfig's SUPABASE_URL/ANON_KEY override prod.

#include "Secrets.xcconfig"
#include? "Secrets-Dev.xcconfig"
